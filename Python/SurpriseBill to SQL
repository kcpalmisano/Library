#Load Python Packages
import pandas as pd
import datetime 
from datetime import date
import os
import pyodbc
import gzip
import glob
import sys
import logging

#Logging for errors / outputs
logging.basicConfig(filename=r'C:\Users\ --PATH-- \Logging\Errors.txt', level=logging.DEBUG,  format='%(asctime)s %(levelname)s %(name)s %(message)s')
logger=logging.getLogger(__name__) 

stdoutOrigin=sys.stdout    ###---output to txt
sys.stdout = open(r'C:\Users\ --PATH-- \Logging\Output.txt', 'a')

### Get date for tracking
today= date.today()   
print('SurpriseBill_ran', today)

#Read in Specs for file location and Data Dictionary Details with full data
dd_map = pd.read_excel('//  --PATH-- /Data Dictionaries.xlsx',
                           sheet_name = 'Empire')   

#Only read in selected columns
use_cols = ['32BJ-CLM-ID','32BJ-LN-ID','32BJ-CLM-ADJ-NO','32BJ-SERV-UNT-NO','SURPRISE_BILLING','QPA_AMOUNT']
dd_map = dd_map[dd_map['Empire Field Name'].isin(use_cols)].reset_index(drop=True)
start_pos = dd_map['Start Position']
end_pos = dd_map['End Position']
positions = []
fields = []


for i in range(len(dd_map)):
    field = dd_map['Empire Field Name'][i].strip()
    pos = [start_pos[i]-1, end_pos[i]]
    positions.append(pos)
    fields.append(field)

#-----------------  Pull data to dataframes
#create empty DFs
df_day = pd.DataFrame()
df_month = pd.DataFrame()

#daily most recent file
list_of_dfiles = glob.iglob('// --PATH-- /Daily Claims Files/WGS/*.pgp') # '*' means all if need specific format then *.csv
latest_dfile = max(list_of_dfiles, key=os.path.getmtime)
print(latest_dfile)

#Daily pull from file
with gzip.open(latest_dfile) as f:
    df = pd.read_fwf(f, names = fields, colspecs = positions) 
    df['File'] = latest_dfile.split("/")[-1]
    df_day = pd.concat([df_day,df], ignore_index=True) 

#df of file 
df_day_out = df_day.groupby(use_cols, as_index=False).agg('; '.join)


#------------------
#monthly most recent
list_of_mfiles = glob.iglob('// --PATH-- /Monthly Claims Files/WGS/*.pgp') 
latest_mfile = max(list_of_mfiles, key=os.path.getmtime)
print(latest_mfile)

#Monthly pull from file
with gzip.open(latest_mfile) as fm:
    dfm = pd.read_fwf(fm, names = fields, colspecs = positions) 
    dfm['File'] = latest_mfile.split("/")[-1]
    df_month = pd.concat([df_month,dfm], ignore_index=True) 

#df of file 
df_month_out = df_month.groupby(use_cols, as_index=False).agg('; '.join)
#-------------------

df_comb_out  = pd.concat([df_month_out, df_day_out])


#Connect to DB via SQL Server
conn = pyodbc.connect('Driver={SQL Server};'   
                      'Server=SERVER;'   ##SERVER NAME
                      'Database=DATABASE;'       ##DATABASE
                      'Trusted_Connection=yes;')
cursor = conn.cursor()

conn.autocommit = True

#Check for database connection
if (conn == False):
    print("Connection DATABASE Error")
else: 
    print("Connection DATABASE Successful")
    
